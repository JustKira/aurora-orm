{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "prerelease": true,
  "prerelease-type": "dev",
  "include-component-in-tag": true,
  "packages": {
    "aureline-cli": {
      "package-name": "aureline-cli",
      "component": "aureline-cli",
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "aureline-tree-sitter/package.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "aureline-codegen": {
      "package-name": "aureline-codegen",
      "component": "aureline-codegen"
    },
    "aureline-config": {
      "package-name": "aureline-config",
      "component": "aureline-config"
    },
    "aureline-core": {
      "package-name": "aureline-core",
      "component": "aureline-core"
    },
    "aureline-lsp": {
      "package-name": "aureline-lsp",
      "component": "aureline-lsp"
    },
    "aureline-migrate": {
      "package-name": "aureline-migrate",
      "component": "aureline-migrate"
    }
  },
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "aureline",
      "components": [
        "aureline-cli",
        "aureline-codegen",
        "aureline-config",
        "aureline-core",
        "aureline-lsp",
        "aureline-migrate"
      ]
    }
  ],
  "separate-pull-requests": false
}
