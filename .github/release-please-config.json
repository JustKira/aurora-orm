{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "package-name": "aureline",
      "component": "aureline",
      "release-type": "rust",
      "include-component-in-tag": false,
      "prerelease": true,
      "prerelease-type": "dev",
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "aureline-tree-sitter/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  },
  "plugins": [
    "cargo-workspace"
  ],
  "separate-pull-requests": false
}
