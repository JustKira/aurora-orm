{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "aurora",
  "displayName": "Aurora",
  "scopeName": "source.aurora",
  "fileTypes": ["aurora"],
  "foldingStartMarker": "\\{\\s*$",
  "foldingStopMarker": "^\\s*\\}",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#surql"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.aurora",
          "match": "^\\s*///.*$"
        },
        {
          "name": "comment.line.double-slash.aurora",
          "match": "//.*$"
        }
      ]
    },
    "surql": {
      "patterns": [
        {
          "name": "meta.embedded.block.surql.aurora",
          "begin": "(#surql)\\s*(\\{)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.directive.surql.aurora"
            },
            "2": {
              "name": "punctuation.section.block.begin.aurora"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.aurora"
            }
          },
          "patterns": [
            {
              "include": "source.surrealql"
            }
          ]
        },
        {
          "name": "meta.embedded.inline.surql.aurora",
          "begin": "(#s)(`)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.directive.surql.aurora"
            },
            "2": {
              "name": "punctuation.definition.string.begin.aurora"
            }
          },
          "end": "`",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.aurora"
            }
          },
          "patterns": [
            {
              "include": "source.surrealql"
            }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "include": "#attribute_with_arguments"
        },
        {
          "name": "entity.name.function.attribute.block.aurora",
          "match": "@@[A-Za-z][A-Za-z0-9_]*"
        },
        {
          "name": "entity.name.function.attribute.aurora",
          "match": "@[A-Za-z][A-Za-z0-9_]*"
        }
      ]
    },
    "attribute_with_arguments": {
      "name": "meta.attribute.with-arguments.aurora",
      "begin": "(@@?[A-Za-z][A-Za-z0-9_]*)(\\()",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.attribute.aurora"
        },
        "2": {
          "name": "punctuation.section.group.begin.aurora"
        }
      },
      "end": "\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.group.end.aurora"
        }
      },
      "patterns": [
        {
          "include": "#surql"
        },
        {
          "include": "#named_argument"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#booleans"
        },
        {
          "include": "#types"
        },
        {
          "include": "#attributes"
        },
        {
          "include": "#punctuation"
        }
      ]
    },
    "named_argument": {
      "name": "meta.attribute.argument.named.aurora",
      "match": "\\b([A-Za-z][A-Za-z0-9_]*)(\\s*:)",
      "captures": {
        "1": {
          "name": "variable.parameter.key.aurora"
        },
        "2": {
          "name": "punctuation.definition.separator.key-value.aurora"
        }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.declaration.aurora",
          "match": "\\b(table|analyzer)\\b"
        },
        {
          "name": "keyword.control.clause.aurora",
          "match": "\\b(tokenizers|filters)\\b"
        },
        {
          "name": "storage.modifier.aurora",
          "match": "\\b(schemafull|schemaless|drop)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.compound.aurora",
          "match": "\\b(option|array|set|record|geometry)\\b"
        },
        {
          "name": "support.type.primitive.aurora",
          "match": "\\b(bool|int|float|decimal|number|string|datetime|duration|uuid|bytes|any|regex|object|range)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.aurora",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.aurora",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.aurora",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.aurora",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.optional.aurora",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.assignment.aurora",
          "match": ":"
        },
        {
          "name": "keyword.operator.union.aurora",
          "match": "\\|"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.aurora",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.group.aurora",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.aurora",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.typeparameters.aurora",
          "match": "[<>]"
        },
        {
          "name": "punctuation.separator.comma.aurora",
          "match": ","
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.table.declaration.aurora",
          "match": "^\\s*(table)\\s+([A-Za-z][A-Za-z0-9_]*)(?:\\s+(schemafull|schemaless|drop))?\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.type.table.aurora"
            },
            "2": {
              "name": "entity.name.type.table.aurora"
            },
            "3": {
              "name": "storage.modifier.aurora"
            },
            "4": {
              "name": "punctuation.definition.block.begin.aurora"
            }
          }
        },
        {
          "name": "meta.analyzer.declaration.aurora",
          "match": "^\\s*(analyzer)\\s+([A-Za-z][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "storage.type.analyzer.aurora"
            },
            "2": {
              "name": "entity.name.type.analyzer.aurora"
            },
            "3": {
              "name": "punctuation.definition.block.begin.aurora"
            }
          }
        },
        {
          "name": "meta.field.definition.aurora",
          "match": "^\\s*([A-Za-z][A-Za-z0-9_]*)(\\s+)(option|array|set|record|geometry|bool|int|float|decimal|number|string|datetime|duration|uuid|bytes|any|regex|object|range)\\b",
          "captures": {
            "1": {
              "name": "variable.other.assignment.field.aurora"
            },
            "3": {
              "name": "support.type.aurora"
            }
          }
        }
      ]
    }
  }
}
